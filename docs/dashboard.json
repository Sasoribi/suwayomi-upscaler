{
  "__inputs": [{ "name": "DS_LOKI", "label": "Loki", "type": "datasource", "pluginId": "loki" }],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": ">=10.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": ">=3.0.0" },
    { "type": "panel", "id": "logs", "name": "Logs" },
    { "type": "panel", "id": "stat", "name": "Stat" },
    { "type": "panel", "id": "timeseries", "name": "Time series" }
  ],
  "annotations": { "list": [{ "builtIn": 1, "datasource": { "type": "datasource", "uid": "grafana" }, "enable": true, "hide": true, "name": "Annotations & Alerts", "type": "dashboard" }] },
  "panels": [
    {
      "type": "stat", "title": "总超分页数",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "noValue": "0", "thresholds": { "mode": "absolute", "steps": [{ "color": "semi-dark-blue" }] } } },
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 0 }, "id": 1,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [{ "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "editorMode": "code", "expr": "sum(count_over_time({host=\"mac-m4\"} |= \"\\\"status\\\":\\\"ok\\\"\" |= \"\\\"msg\\\":\\\"✅\" [48h]))", "queryType": "instant", "refId": "A" }]
    },
    {
      "type": "stat", "title": "平均耗时",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "noValue": "-", "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "orange", "value": 10 }, { "color": "red", "value": 30 }] }, "unit": "s", "decimals": 1 } },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 0 }, "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [{ "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "editorMode": "code", "expr": "avg(avg_over_time({host=\"mac-m4\"} |= \"\\\"status\\\":\\\"ok\\\"\" |= \"\\\"msg\\\":\\\"✅\" | json | unwrap elapsed [48h]))", "queryType": "instant", "refId": "A" }]
    },
    {
      "type": "stat", "title": "最大输出",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "noValue": "-", "thresholds": { "mode": "absolute", "steps": [{ "color": "semi-dark-blue" }] }, "unit": "decmbytes", "decimals": 1 } },
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 0 }, "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [{ "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "editorMode": "code", "expr": "max(max_over_time({host=\"mac-m4\"} |= \"\\\"status\\\":\\\"ok\\\"\" |= \"\\\"msg\\\":\\\"✅\" | json | unwrap size_out_mb [48h]))", "queryType": "instant", "refId": "A" }]
    },
    {
      "type": "stat", "title": "失败次数",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "noValue": "0", "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "red", "value": 1 }] } } },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 0 }, "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [{ "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "editorMode": "code", "expr": "sum(count_over_time({host=\"mac-m4\"} |= \"\\\"status\\\":\\\"fail\\\"\" [48h]))", "queryType": "instant", "refId": "A" }]
    },
    {
      "type": "timeseries", "title": "耗时 P50 / P95 / P99",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "auto", "spanNulls": true, "stacking": { "group": "A", "mode": "none" } }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 3 }, "id": 5,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "editorMode": "code", "expr": "avg(quantile_over_time(0.50, {host=\"mac-m4\"} |= \"\\\"status\\\":\\\"ok\\\"\" | json | unwrap elapsed [5m]))", "legendFormat": "P50", "queryType": "range", "refId": "A" },
        { "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "editorMode": "code", "expr": "avg(quantile_over_time(0.95, {host=\"mac-m4\"} |= \"\\\"status\\\":\\\"ok\\\"\" | json | unwrap elapsed [5m]))", "legendFormat": "P95", "queryType": "range", "refId": "B" },
        { "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "editorMode": "code", "expr": "avg(quantile_over_time(0.99, {host=\"mac-m4\"} |= \"\\\"status\\\":\\\"ok\\\"\" | json | unwrap elapsed [5m]))", "legendFormat": "P99", "queryType": "range", "refId": "C" }
      ]
    },
    {
      "type": "timeseries", "title": "超分速率 (页 / 5 min)",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "bars", "fillOpacity": 80, "showPoints": "never", "spanNulls": true, "stacking": { "group": "A", "mode": "none" } }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 3 }, "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "editorMode": "code", "expr": "sum(count_over_time({host=\"mac-m4\"} |= \"\\\"msg\\\":\\\"✅\" [5m]))", "legendFormat": "超分页数", "queryType": "range", "refId": "A" }]
    },
    {
      "type": "timeseries", "title": "文件尺寸 (原图 vs 超分)",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "auto", "spanNulls": true, "stacking": { "group": "A", "mode": "none" } }, "unit": "decmbytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 }, "id": 7,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "editorMode": "code", "expr": "avg(avg_over_time({host=\"mac-m4\"} |= \"\\\"status\\\":\\\"ok\\\"\" | json | unwrap size_in_mb [5m]))", "legendFormat": "原图", "queryType": "range", "refId": "A" },
        { "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "editorMode": "code", "expr": "avg(avg_over_time({host=\"mac-m4\"} |= \"\\\"status\\\":\\\"ok\\\"\" | json | unwrap size_out_mb [5m]))", "legendFormat": "超分", "queryType": "range", "refId": "B" }
      ]
    },
    {
      "type": "timeseries", "title": "分辨率变化 (宽度)",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "auto", "spanNulls": true, "stacking": { "group": "A", "mode": "none" } }, "unit": "pixel" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 }, "id": 8,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "editorMode": "code", "expr": "avg(avg_over_time({host=\"mac-m4\"} |= \"\\\"status\\\":\\\"ok\\\"\" | json | unwrap in_w [5m]))", "legendFormat": "原图宽", "queryType": "range", "refId": "A" },
        { "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "editorMode": "code", "expr": "avg(avg_over_time({host=\"mac-m4\"} |= \"\\\"status\\\":\\\"ok\\\"\" | json | unwrap out_w [5m]))", "legendFormat": "超分宽", "queryType": "range", "refId": "B" }
      ]
    },
    {
      "type": "logs", "title": "实时日志流",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 }, "id": 9,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showLabels": false, "showTime": true, "sortOrder": "Descending" },
      "targets": [{ "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "editorMode": "code", "expr": "{host=\"mac-m4\"} |= \"\\\"status\\\":\\\"ok\\\"\" | json | line_format \"{{.msg}}  {{.in_w}}x{{.in_h}}→{{.out_w}}x{{.out_h}}  {{.size_in_mb}}→{{.size_out_mb}}MB  {{.elapsed}}s\"", "queryType": "range", "refId": "A" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["suwayomi", "upscaler"],
  "time": { "from": "now-2d", "to": "now" },
  "timepicker": { "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"] },
  "timezone": "browser",
  "title": "Suwayomi Upscaler",
  "uid": "suwayomi-upscaler",
  "version": 1
}
